{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Invoices Sent (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(ksef_invoices_sent_total{job=\"bizflownh-api\"}[5m])) * 60",
          "legendFormat": "Sent"
        },
        {
          "expr": "sum(rate(ksef_invoices_accepted_total{job=\"bizflownh-api\"}[5m])) * 60",
          "legendFormat": "Accepted"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Accepted" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "title": "Errors (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (error_type) (rate(ksef_invoices_errors_total{job=\"bizflownh-api\"}[5m])) * 60",
          "legendFormat": "{{error_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        },
        "overrides": []
      }
    },
    {
      "title": "Rate Limit Hits",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(ksef_ratelimit_hits_total{job=\"bizflownh-api\"}[1h])",
          "legendFormat": "Hits (1h)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 50, "color": "red" }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Poll Timeouts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(ksef_poll_timeouts_total{job=\"bizflownh-api\"}[1h])",
          "legendFormat": "Timeouts (1h)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 3, "color": "yellow" },
              { "value": 10, "color": "red" }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Sessions Opened (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(ksef_sessions_opened_total{job=\"bizflownh-api\"}[1h])",
          "legendFormat": "Sessions"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Poll Attempts (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(ksef_poll_attempts_total{job=\"bizflownh-api\"}[1h])",
          "legendFormat": "Polls"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Send Duration (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ksef_send_duration_seconds_bucket{job=\"bizflownh-api\"}[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ksef_send_duration_seconds_bucket{job=\"bizflownh-api\"}[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ksef_send_duration_seconds_bucket{job=\"bizflownh-api\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 5, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "title": "Session Duration (P50 / P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ksef_session_duration_seconds_bucket{job=\"bizflownh-api\"}[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ksef_session_duration_seconds_bucket{job=\"bizflownh-api\"}[5m])) by (le))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 5, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "title": "Rate Limit Wait Duration (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ksef_ratelimit_wait_duration_seconds_bucket{job=\"bizflownh-api\"}[5m])) by (le))",
          "legendFormat": "P95 wait"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "color": { "fixedColor": "orange", "mode": "fixed" }
        },
        "overrides": []
      }
    },
    {
      "title": "XML Build Duration (P50 / P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ksef_xml_build_duration_seconds_bucket{job=\"bizflownh-api\"}[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ksef_xml_build_duration_seconds_bucket{job=\"bizflownh-api\"}[5m])) by (le))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 5, "lineWidth": 2 }
        },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["bizflownh", "ksef"],
  "time": { "from": "now-3h", "to": "now" },
  "title": "KSeF Pipeline",
  "uid": "bizflownh-ksef-pipeline"
}
