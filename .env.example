# ============================================================
# BizFlow NH — Environment Configuration
# Copy this file to .env and fill in the values
# Generated by install.sh — manual editing not recommended
# ============================================================

# ── ACR Credentials (provided by BizCode) ──
ACR_USERNAME=
ACR_PASSWORD=

# ── PostgreSQL ──
POSTGRES_PASSWORD=changeme

# ── RabbitMQ ──
RABBITMQ_USER=bizflownh
RABBITMQ_PASSWORD=changeme

# ── JWT ──
JWT_KEY=changeme-generate-a-random-key-at-least-32-chars

# ── KSeF ──
# test = https://ksef-test.mf.gov.pl
# demo = https://ksef-demo.mf.gov.pl
# prod = https://ksef.mf.gov.pl
KSEF_BASE_URL=https://ksef-test.mf.gov.pl

# ── OpenBao (Secrets / Certificates) ──
OPENBAO_ROLE_ID=
OPENBAO_SECRET_ID=

# ── MinIO (Object Storage) ──
MINIO_ACCESS_KEY=changeme
MINIO_SECRET_KEY=changeme

# ── Frontend URLs (for CORS) ──
LANDING_URL=https://example.com
DASHBOARD_URL=https://app.example.com

# ── Auto-update interval (seconds, 0 = disabled) ──
WATCHTOWER_INTERVAL=300
